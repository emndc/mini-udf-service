# ═════════════════════════════════════════════════════════════════════
# Mini UDF Service - Production Configuration
# ═════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values
# DO NOT commit .env to git (add to .gitignore)
#

# ─── Environment ────────────────────────────────────────────────────
ENVIRONMENT=production
FLASK_DEBUG=False
FLASK_ENV=production

# ─── Security (CRITICAL) ────────────────────────────────────────────
# Generate a strong API key:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
API_SECRET_KEY=your-super-secret-api-key-here-generate-strong-key

# CORS whitelist - URLs that can call this API
# Use comma-separated list for multiple origins
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,https://admin.yourdomain.com

# ─── Server ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5055

# Max file size for uploads (bytes)
# Default: 50MB = 52428800 bytes
MAX_FILE_SIZE=52428800

# ─── Logging ────────────────────────────────────────────────────────
# LOG_LEVEL=WARNING (for production, INFO for development)
LOG_LEVEL=WARNING

# ─── Rate Limiting ───────────────────────────────────────────────────
# Optional: Use Redis for distributed rate limiting
# REDIS_URL=redis://localhost:6379/0
# Leave empty to use in-memory limiter (single server only)
REDIS_URL=

# ─── Gunicorn Configuration ──────────────────────────────────────────
# Number of worker processes
GUNICORN_WORKERS=4

# Number of threads per worker (for concurrency)
GUNICORN_THREADS=2

# Max requests per worker (helps prevent memory leaks)
GUNICORN_MAX_REQUESTS=1000

# Timeout for requests (seconds)
GUNICORN_TIMEOUT=30

# ─── Monitoring ─────────────────────────────────────────────────────
# Enable detailed health check endpoint
HEALTH_CHECK_ENABLED=True

# ═════════════════════════════════════════════════════════════════════
# DEPLOYMENT INSTRUCTIONS:
# ═════════════════════════════════════════════════════════════════════
#
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and set real values
# 3. Generate secure API key:
#    python -c "import secrets; print(secrets.token_urlsafe(64))"
# 4. Set API key in .env: API_SECRET_KEY=<generated-key>
# 5. Deploy:
#    
#    # Using Gunicorn (Linux/macOS)
#    gunicorn -w 4 --threads 2 -b 0.0.0.0:5055 mini_udf_service_secure:app
#    
#    # Using Gunicorn on Windows
#    python -m gunicorn -w 4 --threads 2 -b 0.0.0.0:5055 mini_udf_service_secure:app
#    
#    # Or use the provided start script:
#    ./start_production.sh  (Linux/macOS)
#    .\start_production.ps1 (Windows)
#
